default_platform(:ios)

# Load App Store Connect API credentials from the gitignored .secrets/ dir at the repo root.
# .secrets/asc_api.env defines ASC_KEY_ID, ASC_ISSUER_ID, ASC_P8_PATH (relative to repo root).
def load_asc_env
  env_path = File.expand_path("../.secrets/asc_api.env", __dir__)
  UI.user_error!("Missing #{env_path} — see fastlane/README.md") unless File.exist?(env_path)
  File.readlines(env_path).each do |line|
    line = line.strip
    next if line.empty? || line.start_with?("#") || !line.include?("=")
    k, v = line.split("=", 2)
    ENV[k] ||= v
  end
end

def asc_api_key
  load_asc_env
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: File.expand_path("../#{ENV.fetch('ASC_P8_PATH')}", __dir__),
  )
end

platform :ios do
  desc "Upload localized App Store metadata + screenshots as drafts (does NOT submit)"
  lane :upload_listing do
    upload_to_app_store(
      api_key: asc_api_key,
      app_identifier: "com.halfspud.ScreenTimeShield",
      metadata_path: File.expand_path("metadata", __dir__),
      screenshots_path: File.expand_path("screenshots", __dir__),
      skip_binary_upload: true,
      overwrite_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      force: true, # skip the interactive HTML metadata preview
    )
  end

  desc "Validate metadata before submission (no upload)"
  lane :check_listing do
    precheck(api_key: asc_api_key, app_identifier: "com.halfspud.ScreenTimeShield")
  end
end
